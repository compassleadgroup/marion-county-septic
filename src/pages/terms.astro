---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../data/site';

const title = 'Terms of Service | Marion County Septic';
const description =
  'The terms governing your use of Marion County Septic, a marketing and lead generation service operated by Compass Camper LLC.';
const updated = 'June 2026';
---
<BaseLayout title={title} description={description}>
  <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Terms of Service', path: '/terms/' }]} />
  <article class="container-narrow rich py-8">
    <h1>Terms of Service</h1>
    <p>Last updated: {updated}</p>

    <p>
      These terms govern your use of {site.brandName} ({site.domain}), operated by
      {site.entity.legalName} ({site.entity.state}). By using this website or
      submitting a request, you agree to these terms.
    </p>

    <h2>Our service</h2>
    <p>
      {site.brandName} is a marketing and lead generation service. We connect
      property owners in Marion County, Florida with independent, licensed septic
      contractors. We are not a septic contractor, we do not perform septic work,
      and we do not negotiate the scope or price of any job.
    </p>

    <h2>No contractor relationship or warranty</h2>
    <p>
      Any septic work is performed by an independent licensed contractor with whom
      you contract directly. We do not employ those contractors, supervise their
      work, or guarantee their services. We make no warranty, express or implied,
      regarding any contractor or any work they perform. Your agreement for any
      work is solely between you and the contractor.
    </p>

    <h2>Information you provide</h2>
    <p>
      You agree that the information you submit is accurate and that you are
      authorized to provide it, and you consent to be contacted as described in
      our <a class="link-inline" href="/privacy/">Privacy Policy</a> and in the
      consent you provide on our forms.
    </p>

    <h2>Limitation of liability</h2>
    <p>
      To the fullest extent permitted by law, {site.entity.legalName} is not
      liable for any indirect, incidental, or consequential damages arising from
      your use of this website or from any work performed by a contractor. To the
      extent any liability is found, it is limited to a nominal amount or the value
      of the lead, whichever is applicable.
    </p>

    <h2>Governing law and disputes</h2>
    <p>
      These terms are governed by the laws of the State of {site.entity.state}.
      Any dispute will be resolved in the state or federal courts located in
      {site.entity.state}, or, at either party's election, through binding
      arbitration.
    </p>

    <h2>Contact</h2>
    <p>
      Questions about these terms can be sent to
      <a class="link-inline" href={`mailto:${site.email}`}>{site.email}</a>.
    </p>
  </article>
</BaseLayout>
