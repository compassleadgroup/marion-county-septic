---
import BaseLayout from '../layouts/BaseLayout.astro';
import { phone } from '../data/site';
import { backboneGuides } from '../data/guides';

const title = 'Thank You | Marion County Septic';
const description = 'Your request has been received. A licensed local septic contractor will be in touch to schedule your free quote.';
---
<BaseLayout title={title} description={description} noindex={true}>
  <section class="container-narrow py-16 text-center">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-spring">
      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="m5 13 4 4L19 7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
    <h1 class="mt-6 font-heading text-3xl font-extrabold text-spring-dark sm:text-4xl">
      Thank you, your request is in
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-ink/85">
      We have received your details and will connect you with a licensed local
      septic contractor who can schedule your free, no-obligation quote. If you
      need to reach us sooner, call
      <a class="link-inline" href={`tel:${phone.tel}`}>{phone.display}</a>.
    </p>

    <div class="mx-auto mt-10 max-w-2xl text-left">
      <h2 class="font-heading text-xl font-bold text-spring-dark">While you wait</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {backboneGuides.map((g) => (
          <a class="group rounded-xl border border-sage bg-white p-5 hover:border-spring" href={`/guides/${g.slug}/`}>
            <p class="font-heading font-bold text-spring-dark group-hover:text-spring">{g.title}</p>
            <p class="mt-1 text-sm text-ink/80">{g.cardSummary}</p>
          </a>
        ))}
      </div>
      <p class="mt-8 text-center">
        <a class="btn-secondary" href="/">Back to home</a>
      </p>
    </div>
  </section>

  <!-- GA4 lead conversion (fires once per completed submission, covering both
       the JS and the no-JS native-redirect submit paths). -->
  <script is:inline>
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'generate_lead', {
        event_category: 'quote_form',
        event_label: 'quote_request',
      });
    }
  </script>
</BaseLayout>
