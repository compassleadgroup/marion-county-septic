---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import QuoteForm from '../components/QuoteForm.astro';
import FaqBlock from '../components/FaqBlock.astro';
import { site, phone } from '../data/site';
import { services } from '../data/services';
import { backboneGuides } from '../data/guides';
import { homeFaqs } from '../data/faqs';

const title = 'Marion County Septic | New Systems & Drainfield Replacement';
const description =
  'Get matched with licensed local septic contractors in Marion County, FL for new system installation, drainfield replacement, and advanced treatment. Free, no-obligation quotes.';

const steps = [
  {
    n: '1',
    title: 'Tell us about your project',
    body: 'Share your property, your town, and what you need, from a new system to a failed drainfield.',
  },
  {
    n: '2',
    title: 'We match you with a contractor',
    body: 'Your request goes to a licensed local septic contractor who can handle the permit and the work.',
  },
  {
    n: '3',
    title: 'Get a free quote',
    body: 'The contractor contacts you to schedule a free, no-obligation quote. You are never obligated to hire.',
  },
];
---
<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-mist to-sand">
    <div class="container-x grid items-center gap-10 py-14 lg:grid-cols-2 lg:py-20">
      <div>
        <p class="font-heading text-sm font-semibold uppercase tracking-wide text-aqua">
          Free contractor matching &middot; Marion County, FL
        </p>
        <h1 class="mt-3 font-heading text-4xl font-extrabold leading-tight text-spring-dark sm:text-5xl">
          Get matched with licensed Marion County septic contractors
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-ink/85">
          {site.brandName} connects property owners with licensed local contractors
          for new septic system installation, drainfield replacement, and advanced
          treatment systems. Tell us about your project and get a free,
          no-obligation quote.
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-4">
          <a class="btn-primary" href="#quote">Get a free quote</a>
          <a class="btn-secondary" href={`tel:${phone.tel}`}>Call {phone.display}</a>
        </div>
        <p class="mt-5 text-sm text-ink/70">
          Planned, permitted work only: new installs, full drainfield replacement,
          and advanced treatment. For an emergency backup, call a local company directly.
        </p>
      </div>

      <!-- Decorative spring/ripple panel (CSS/SVG, no image payload) -->
      <div class="relative hidden lg:block" aria-hidden="true">
        <div class="rounded-3xl border border-sage bg-white p-8 shadow-sm">
          <svg viewBox="0 0 400 260" class="w-full" role="img" aria-hidden="true">
            <defs>
              <linearGradient id="spring-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#2A8C8C" />
                <stop offset="1" stop-color="#0F5257" />
              </linearGradient>
            </defs>
            <rect x="0" y="0" width="400" height="260" rx="16" fill="#EEF4F2" />
            <path d="M0 150 Q 100 120 200 150 T 400 150 V 260 H 0 Z" fill="url(#spring-grad)" opacity="0.9" />
            <path d="M0 175 Q 100 145 200 175 T 400 175 V 260 H 0 Z" fill="#0B3F43" opacity="0.85" />
            <circle cx="300" cy="70" r="26" fill="#C6892F" opacity="0.9" />
            <g stroke="#0F5257" stroke-width="3" fill="none" opacity="0.5">
              <path d="M40 70 q 20 -16 40 0 t 40 0" />
              <path d="M40 92 q 20 -16 40 0 t 40 0" />
            </g>
          </svg>
          <p class="mt-5 font-heading text-lg font-bold text-spring-dark">
            Built for spring country
          </p>
          <p class="mt-1 text-sm text-ink/75">
            Much of Marion County sits in the Silver Springs and Rainbow Springs
            protection zones, where advanced treatment systems are often required.
            We help you find a contractor who knows the rules.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="container-x py-14">
    <h2 class="text-center font-heading text-3xl font-bold text-spring-dark">How it works</h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-ink/80">
      A free, three-step way to reach a licensed local septic contractor.
    </p>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {steps.map((s) => (
        <div class="rounded-2xl border border-sage bg-white p-6">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-spring font-heading text-lg font-bold text-white">
            {s.n}
          </span>
          <h3 class="mt-4 font-heading text-xl font-bold text-spring-dark">{s.title}</h3>
          <p class="mt-2 text-ink/80">{s.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Services -->
  <section class="bg-mist/60">
    <div class="container-x py-14">
      <h2 class="font-heading text-3xl font-bold text-spring-dark">
        What kind of septic project do you have?
      </h2>
      <p class="mt-3 max-w-2xl text-ink/80">
        We match you with a licensed local contractor for planned, permitted septic
        work across {site.county}.
      </p>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => <ServiceCard service={s} />)}
      </div>
    </div>
  </section>

  <!-- Marion County trust block -->
  <section class="container-x py-14">
    <div class="grid gap-8 rounded-3xl border border-sage bg-white p-8 lg:grid-cols-2 lg:p-10">
      <div>
        <h2 class="font-heading text-2xl font-bold text-spring-dark sm:text-3xl">
          Septic in Marion County, done by the book
        </h2>
        <p class="mt-4 leading-relaxed text-ink/85">
          Marion County is sandy, spring-fed, and growing fast. New systems and
          drainfield replacements are permitted projects with real rules around
          soils, setbacks, and water quality. As of July 1, 2025, onsite sewage
          (OSTDS) permits here are administered by the Florida Department of
          Environmental Protection (FDEP).
        </p>
        <p class="mt-4 leading-relaxed text-ink/85">
          We are not a contractor. We are a local information resource and a free
          matching service. Start with our guides, then get matched with a licensed
          contractor who works in your area.
        </p>
      </div>
      <div class="flex flex-col justify-center gap-4">
        {backboneGuides.map((g) => (
          <a
            href={`/guides/${g.slug}/`}
            class="group rounded-xl border border-sage bg-mist/50 p-5 transition-colors hover:border-spring"
          >
            <p class="font-heading text-lg font-bold text-spring-dark group-hover:text-spring">
              {g.title}
            </p>
            <p class="mt-1 text-sm text-ink/80">{g.cardSummary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote form -->
  <section class="container-x pb-6">
    <div class="mx-auto max-w-3xl">
      <QuoteForm />
    </div>
  </section>

  <!-- FAQ -->
  <FaqBlock faqs={homeFaqs} />
</BaseLayout>
