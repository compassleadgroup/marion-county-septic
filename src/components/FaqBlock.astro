---
/*
  Accessible FAQ accordion (native <details>, no JS) + FAQPage JSON-LD.
  The visible answer and the schema answer come from the same data, so they
  always match (COMPLIANCE_STANDARDS.md). Emit at most one FAQPage per page.
*/
import SchemaOrg from './SchemaOrg.astro';
import { buildFaqPage, type FaqItem } from '../lib/schema';

interface Props {
  faqs: FaqItem[];
  heading?: string;
  emitSchema?: boolean;
}
const { faqs, heading = 'Frequently asked questions', emitSchema = true } = Astro.props;
const schema = buildFaqPage(faqs);
---
<section class="container-narrow py-12">
  <h2 class="font-heading text-2xl font-bold text-spring-dark sm:text-3xl">{heading}</h2>
  <div class="mt-6 divide-y divide-sage rounded-2xl border border-sage bg-white">
    {faqs.map((f) => (
      <details class="group p-5">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-heading text-lg font-semibold text-spring-dark">
          {f.question}
          <svg class="shrink-0 transition-transform group-open:rotate-45" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </summary>
        <p class="mt-3 leading-relaxed text-ink/85">{f.answer}</p>
      </details>
    ))}
  </div>
</section>
{emitSchema && <SchemaOrg schema={schema} />}
