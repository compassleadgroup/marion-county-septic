---
/*
  Outbound authoritative citations. These links are a deliberate Trust / E-E-A-T
  signal, so they are real followed links to .gov and authoritative sources.
*/
interface Source {
  label: string;
  url: string;
}
interface Props {
  sources: Source[];
  heading?: string;
}
const { sources, heading = 'Sources and where to verify' } = Astro.props;
---
{sources.length > 0 && (
  <section class="mt-10 rounded-xl border border-sage bg-white p-5">
    <h2 class="font-heading text-lg font-bold text-spring-dark">{heading}</h2>
    <ul class="mt-3 space-y-2 text-sm">
      {sources.map((s) => (
        <li>
          <a
            class="link-inline break-words"
            href={s.url}
            target="_blank"
            rel="noopener"
          >
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
