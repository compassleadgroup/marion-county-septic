---
/*
  Service card used on the home page and elsewhere. Neutral framing only.
  The springs/BMAP service uses the reserved aqua accent.
*/
import type { Service } from '../data/services';

interface Props {
  service: Service;
}
const { service } = Astro.props;
const accent = service.springsAccent ? 'aqua' : 'spring';
---
<a
  href={`/services/${service.slug}/`}
  class="group flex h-full flex-col rounded-2xl border border-sage bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
>
  <div class="flex items-center gap-2">
    <span
      class="inline-block h-2.5 w-2.5 rounded-full"
      style={`background-color: var(--color-${accent})`}
      aria-hidden="true"
    ></span>
    {service.flagship && (
      <span class="rounded-full bg-mist px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-spring">
        Most requested
      </span>
    )}
  </div>
  <h3 class="mt-3 font-heading text-xl font-bold text-spring-dark group-hover:text-spring">
    {service.name}
  </h3>
  <p class="mt-2 flex-1 text-ink/80">{service.cardSummary}</p>
  <span class="mt-4 inline-flex items-center gap-1 font-heading text-sm font-semibold text-ochre-dark">
    Learn more
    <svg class="transition-transform group-hover:translate-x-1" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>
