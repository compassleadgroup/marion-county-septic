---
/*
  Global site header (nav). The disclosure strip is rendered above this in
  BaseLayout. Desktop uses CSS-only dropdowns (hover + focus-within); mobile
  uses a no-JS checkbox toggle so the menu works without client JavaScript.
*/
import { site, phone } from '../data/site';
import { services } from '../data/services';
import { guides } from '../data/guides';

const navLink =
  'font-heading text-[0.95rem] font-medium text-ink hover:text-spring transition-colors';
---
<header class="border-b border-sage bg-sand">
  <!-- peer toggle for the mobile menu (no JS) -->
  <input id="nav-toggle" type="checkbox" class="peer sr-only" aria-hidden="true" />

  <div class="container-x flex items-center justify-between gap-4 py-3">
    <!-- Brand -->
    <a href="/" class="flex items-center gap-2.5" aria-label={`${site.brandName} home`}>
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M12 2.5c4 4.8 7 8.3 7 12a7 7 0 1 1-14 0c0-3.7 3-7.2 7-12Z"
          fill="#0F5257"
        />
        <path
          d="M9.2 13.2c0 1.9 1.4 3.3 3 3.3"
          stroke="#FBF8F3"
          stroke-width="1.5"
          stroke-linecap="round"
        />
      </svg>
      <span class="font-heading text-lg font-bold leading-none text-spring-dark">
        {site.brandName}
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 lg:flex" aria-label="Primary">
      <!-- Services dropdown -->
      <div class="group relative">
        <button class={`${navLink} inline-flex items-center gap-1`} aria-haspopup="true">
          Services
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div class="absolute left-0 top-full z-40 hidden min-w-[18rem] pt-3 group-hover:block group-focus-within:block">
          <ul class="rounded-lg border border-sage bg-white p-2 shadow-lg">
            {services.map((s) => (
              <li>
                <a class="block rounded-md px-3 py-2 text-sm text-ink hover:bg-mist hover:text-spring" href={`/services/${s.slug}/`}>
                  {s.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Guides dropdown -->
      <div class="group relative">
        <button class={`${navLink} inline-flex items-center gap-1`} aria-haspopup="true">
          Guides
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div class="absolute left-0 top-full z-40 hidden min-w-[18rem] pt-3 group-hover:block group-focus-within:block">
          <ul class="rounded-lg border border-sage bg-white p-2 shadow-lg">
            {guides.map((g) => (
              <li>
                <a class="block rounded-md px-3 py-2 text-sm text-ink hover:bg-mist hover:text-spring" href={`/guides/${g.slug}/`}>
                  {g.navLabel}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <a class={navLink} href="/locations/">Service Areas</a>
      <a class={navLink} href="/about/">About</a>
      <a class={navLink} href="/contact/">Contact</a>
      <a class="btn-primary text-sm" href="/contact/#quote">Get a Quote</a>
    </nav>

    <!-- Mobile controls -->
    <div class="flex items-center gap-3 lg:hidden">
      <a class="btn-primary px-4 py-2 text-sm" href="/contact/#quote">Quote</a>
      <label
        for="nav-toggle"
        class="inline-flex cursor-pointer items-center justify-center rounded-md border border-sage p-2 text-spring-dark"
        aria-label="Toggle navigation menu"
      >
        <svg class="peer-checked:hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <svg class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </label>
    </div>
  </div>

  <!-- Mobile menu panel (revealed by the peer checkbox) -->
  <div class="hidden border-t border-sage bg-white peer-checked:block lg:!hidden">
    <nav class="container-x flex flex-col gap-1 py-4" aria-label="Mobile">
      <details class="border-b border-sage/60 py-1">
        <summary class="cursor-pointer list-none py-2 font-heading font-semibold text-spring-dark">
          Services
        </summary>
        <ul class="pb-2 pl-3">
          {services.map((s) => (
            <li><a class="block py-2 text-sm text-ink hover:text-spring" href={`/services/${s.slug}/`}>{s.name}</a></li>
          ))}
        </ul>
      </details>

      <details class="border-b border-sage/60 py-1">
        <summary class="cursor-pointer list-none py-2 font-heading font-semibold text-spring-dark">
          Guides
        </summary>
        <ul class="pb-2 pl-3">
          {guides.map((g) => (
            <li><a class="block py-2 text-sm text-ink hover:text-spring" href={`/guides/${g.slug}/`}>{g.navLabel}</a></li>
          ))}
        </ul>
      </details>

      <a class="border-b border-sage/60 py-3 font-heading font-semibold text-spring-dark" href="/locations/">Service Areas</a>
      <a class="border-b border-sage/60 py-3 font-heading font-semibold text-spring-dark" href="/about/">About</a>
      <a class="border-b border-sage/60 py-3 font-heading font-semibold text-spring-dark" href="/contact/">Contact</a>

      <a class="mt-3 inline-flex items-center justify-center gap-2 font-heading font-semibold text-spring" href={`tel:${phone.tel}`}>
        Call {phone.display}
      </a>
    </nav>
  </div>
</header>
