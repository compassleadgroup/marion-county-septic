---
/*
  Reusable call-to-action band. Neutral matching-service framing only.
*/
import { phone } from '../data/site';
interface Props {
  heading?: string;
  sublabel?: string;
  href?: string;
}
const {
  heading = 'Ready to get matched with a licensed contractor?',
  sublabel = 'Tell us about your project and get a free, no-obligation quote from a licensed local septic contractor.',
  href = '/contact/#quote',
} = Astro.props;
---
<section class="bg-spring">
  <div class="container-x py-12 text-center">
    <h2 class="font-heading text-2xl font-bold text-white sm:text-3xl">{heading}</h2>
    <p class="mx-auto mt-3 max-w-2xl text-mist/90">{sublabel}</p>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-4">
      <a class="btn-primary" href={href}>Get a free quote</a>
      <a class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/70 px-6 py-3 font-heading font-semibold text-white hover:bg-white/10" href={`tel:${phone.tel}`}>
        Call {phone.display}
      </a>
    </div>
  </div>
</section>
