# Marion County Septic - environment variables
# Set these in the Cloudflare Pages dashboard (Settings > Environment variables).
# Never commit real values. The .env file is gitignored.
#
# Web3Forms access key (domain-locked to marioncountyseptic.com).
PUBLIC_WEB3FORMS_KEY=

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX. Leave blank to disable.
PUBLIC_GA4_ID=

# Optional: override the displayed contact phone number without a code change.
# Display format (XXX) XXX-XXXX and tel format +1XXXXXXXXXX.
# If unset, the placeholder in src/data/site.ts is used.
PUBLIC_PHONE_DISPLAY=
PUBLIC_PHONE_TEL=
